{
  "hosting": [
    {
      "target": "booking",
      "public": "web",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "marketing/**"],
      "rewrites": [
        { "source": "/join", "destination": "/join.html" },
        { "source": "**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=0, must-revalidate"
            },
            {
              "key": "Content-Security-Policy",
              "value": "frame-ancestors 'self' https://getbookking.com https://www.getbookking.com https://getbooking.com https://www.getbooking.com https://test-app-96812.web.app https://test-app-96812-marketing.web.app"
            }
          ]
        },
        {
          "source": "**/*.@(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff2)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    },
    {
      "target": "marketing",
      "public": "web/marketing",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/admin/login", "destination": "/admin/login.html" },
        { "source": "/admin/welcome", "destination": "/admin/welcome.html" },
        { "source": "/admin", "destination": "/admin/requests.html" },
        { "source": "/admin/requests", "destination": "/admin/requests.html" },
        { "source": "/admin/bugs", "destination": "/admin/bugs.html" },
        { "source": "/admin/reports", "destination": "/admin/reports.html" },
        { "source": "/admin/testflight", "destination": "/admin/testflight.html" },
        { "source": "/admin/settings", "destination": "/admin/settings.html" },
        { "source": "/beta/login", "destination": "/beta/login.html" },
        { "source": "/beta/report-bug", "destination": "/beta/report-bug.html" },
        { "source": "/beta", "destination": "/beta/index.html" },
        { "source": "/login", "destination": "/login.html" }
      ],
      "headers": [
        {
          "source": "**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=0, must-revalidate"
            }
          ]
        },
        {
          "source": "assets/brand/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=3600, must-revalidate"
            }
          ]
        },
        {
          "source": "**/*.@(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff2)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    }
  ],
  "functions": {
    "source": "functions"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
