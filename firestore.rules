rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userTenantIdMatches(tenantId) {
      return isSignedIn()
        && exists(userPath())
        && get(userPath()).data.tenantId == tenantId;
    }

    function isTenantOwnerUid(tenantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/tenants/$(tenantId))
        && get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUid == request.auth.uid;
    }

    function canManageTenant(tenantId) {
      return userTenantIdMatches(tenantId) || isTenantOwnerUid(tenantId);
    }

    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /tenantInvites/{inviteId} {
      allow read, write: if false;
    }

    match /tenants/{tenantId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update: if canManageTenant(tenantId)
        && (!('ownerUid' in resource.data) || request.resource.data.ownerUid == resource.data.ownerUid);

      allow delete: if canManageTenant(tenantId);

      match /services/{serviceId} {
        allow read: if true;
        allow write: if canManageTenant(tenantId);
      }

      match /products/{productId} {
        allow read: if true;
        allow write: if canManageTenant(tenantId);
      }

      match /customers/{customerId} {
        allow read, write: if canManageTenant(tenantId);
      }

      match /bookingRequests/{requestId} {
        allow read, write: if canManageTenant(tenantId);
      }
    }
  }
}
