rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function userTenantId() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.tenantId;
    }

    function canWriteTenantTree(tenantId) {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userTenantId() == tenantId;
    }

    // Web booking intake: tenantRefImages/{tenantId}/{uploadId}/{filename}
    // Requires Anonymous Auth (Firebase Console) so request.auth is set.
    match /tenantRefImages/{tenantId}/{uploadId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
    }

    match /users/{uid}/profile.jpg {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                  && request.auth.uid == uid
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
    }

    // Writes require image/* on the object (set StorageMetadata.contentType in app SDKs; nil metadata → permission denied).
    match /tenants/{tenantId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*')
                  && canWriteTenantTree(tenantId);
    }

    // Beta bug report attachments (tester uploads to own uid folder).
    match /betaBugAttachments/{uid}/{uploadId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                  && request.auth.uid == uid
                  && request.resource.size < 25 * 1024 * 1024
                  && (request.resource.contentType.matches('image/.*')
                      || request.resource.contentType.matches('video/.*')
                      || request.resource.contentType == 'application/pdf');
    }
  }
}
