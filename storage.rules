rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Reference images from web intake form: tenantRefImages/{tenantId}/{uploadId}/{filename}
    match /tenantRefImages/{tenantId}/{uploadId}/{filename} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');
    }
  }
}
